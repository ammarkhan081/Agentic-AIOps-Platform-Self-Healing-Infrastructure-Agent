# LLM Provider
LLM_PROVIDER=groq

# Groq (temporary active provider while developing on free tier)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_HEAVY=llama3-70b-8192
GROQ_MODEL_LIGHT=llama3-8b-8192

# OpenAI (optional provider switch / future migration path)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_HEAVY=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=ashia-aiops
LANGSMITH_PROJECT_URL=
DEMO_VIDEO_URL=
PUBLIC_DEPLOYMENT_URL=

# Optional Pinecone Memory (legacy migration path; default runtime uses local ChromaDB)
# Optional legacy vector-memory path. ChromaDB is the active local default.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ashia-incidents
PINECONE_NAMESPACE=production

# Database
POSTGRES_USER=ashia
POSTGRES_PASSWORD=ashia_secret
POSTGRES_DB=ashia_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ashia:ashia_secret@localhost:5432/ashia_db

# Redis
REDIS_URL=redis://localhost:6379

# Observability Stack
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686
ORDER_SERVICE_URL=http://localhost:8002
USER_SERVICE_URL=http://localhost:8001
API_GATEWAY_URL=http://localhost:8000
USER_DB_POOL_MAX=20
ORDER_REDIS_PREFIX=ashia:orders

# Slack (HITL Notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SEED_DEMO_USERS=false

# App Config
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=INFO

# Anomaly Detection Thresholds
ANOMALY_ZSCORE_THRESHOLD=2.5
ANOMALY_CONSECUTIVE_READINGS=3
MONITOR_POLL_INTERVAL_SECONDS=30
MAX_RETRY_COUNT=3
HITL_TIMEOUT_MINUTES=15
AUTO_MONITOR_ENABLED=true
